# Copy these to .env and fill in API keys. 
# Never commit real API keys!
PERSPECTIVE_API_KEY=your_perspective_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: tune rate limits (seconds between API calls)
PERSPECTIVE_SLEEP_SECS=1.1
GEMINI_SLEEP_SECS=2.0
CLAUDE_SLEEP_SECS=0.5